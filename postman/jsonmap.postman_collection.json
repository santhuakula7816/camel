{
  "openapi": "3.0.3",
  "info": {
    "title": "JSON Map Service API",
    "version": "1.0.0",
    "description": "API for managing JSON mapping data"
  },
  "servers": [
    {
      "url": "http://localhost:8084",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/json/{id}": {
      "put": {
        "tags": [
          "mapper-json-controller"
        ],
        "summary": "Update JSON mapping",
        "operationId": "update",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Unique ID of the JSON mapping",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MapperJson"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON mapping updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MapperJson"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "mapper-json-controller"
        ],
        "summary": "Delete JSON mapping",
        "operationId": "delete",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Unique ID of the JSON mapping",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JSON mapping deleted successfully"
          }
        }
      }
    },
    "/json/create": {
      "post": {
        "tags": [
          "mapper-json-controller"
        ],
        "summary": "Create JSON mapping",
        "operationId": "createRack",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "additionalProperties": {
                  "type": "object"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JSON mapping created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MapperJson"
                }
              }
            }
          }
        }
      }
    },
    "/json/getAll": {
      "get": {
        "tags": [
          "mapper-json-controller"
        ],
        "summary": "Get all JSON mappings",
        "operationId": "getAllLocations",
        "responses": {
          "200": {
            "description": "List of all JSON mappings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MapperJson"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MapperJson": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "12345"
          },
          "data": {
            "type": "object",
            "additionalProperties": {
              "type": "object"
            },
            "example": {
              "name": "sample",
              "value": {
                "key": "value"
              }
            }
          }
        }
      }
    }
  }
}